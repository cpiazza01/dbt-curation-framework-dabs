-- Generated by dbt-curation-generate.
-- Ensures models use their configured +schema value exactly, without prepending
-- the target schema. Required for pre_gold/gold routing to work correctly.
{% raw %}{% macro generate_schema_name(custom_schema_name, node) -%}
    {%- if custom_schema_name is none -%}
        {{ target.schema }}
    {%- else -%}
        {{ custom_schema_name | trim }}
    {%- endif -%}
{%- endmacro %}{% endraw %}
