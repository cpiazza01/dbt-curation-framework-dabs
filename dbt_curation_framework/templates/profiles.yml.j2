# profiles.yml — generated by dbt-curation-generate for local development only.
# The Databricks Workflow job handles authentication automatically at runtime.
#
# Set these environment variables before running dbt locally:
#   DATABRICKS_HOST       Workspace URL, e.g. https://adb-123456789.azuredatabricks.net
#   DATABRICKS_HTTP_PATH  SQL warehouse HTTP path, e.g. /sql/1.0/warehouses/abc123
#
# On first run, dbt will open a browser window for SSO login (OAuth).

default:
  target: dev
  outputs:
    dev:
      type: databricks
{% raw %}
      host: "{{ env_var('DATABRICKS_HOST') }}"
      http_path: "{{ env_var('DATABRICKS_HTTP_PATH') }}"
{% endraw %}
      auth_type: databricks-oauth
      catalog: {{ catalog }}
      schema: pre_gold
      threads: 4
